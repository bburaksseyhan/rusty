{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/admin", "destination": "/api" }
  ],
  "functions": {
    "api/[[...path]].js": {
      "includeFiles": "server/admin.html",
      "maxDuration": 10
    }
  }
}
