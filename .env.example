# API sunucusu
PORT=3001
CORS_ORIGIN=http://localhost:5173
FEEDBACK_DB_PATH=./data/feedback.db

# Rate limit (IP başına)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=8

# Dashboard — /admin (Basic Auth)
ADMIN_USER=kai
ADMIN_PASS=change-me

# Vite — boş bırakırsan dev proxy /api kullanır
# VITE_API_BASE_URL=http://localhost:3001

# --- Vercel (rusty-sigma.vercel.app) ---
# Settings → Environment Variables: ADMIN_USER, ADMIN_PASS
# Dashboard: https://rusty-sigma.vercel.app/admin
# Analytics: Proje → Analytics → Enable
