# API sunucusu
PORT=3001
CORS_ORIGIN=http://localhost:5173
FEEDBACK_DB_PATH=./data/feedback.db

# Rate limit (IP başına)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=8

# Rapor paneli — ZORUNLU (Basic Auth, kullanıcı adı + şifre olmadan açılmaz)
# /admin  /api/admin/stats  /api/admin/feedback
ADMIN_USER=kai
ADMIN_PASS=change-me-güçlü-bir-şifre

# Vite — boş bırakırsan dev proxy /api kullanır
# VITE_API_BASE_URL=http://localhost:3001

# --- Vercel (rusty-sigma.vercel.app) ---
# Settings → Environment Variables:
#   ADMIN_USER, ADMIN_PASS
#   Upstash / Vercel KV (Storage → Upstash Redis → Connect) — ikisi de olur:
#     KV_REST_API_URL + KV_REST_API_TOKEN  (Vercel entegrasyonu)
#     veya UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN
# Dashboard: https://rusty-sigma.vercel.app/admin
# Analytics: Proje → Analytics → Enable
